{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pacto.trianalab.com/schema/v1.0",
  "title": "Pacto Service Contract v1.0",
  "type": "object",
  "required": ["pactoVersion", "service", "interfaces", "runtime"],
  "additionalProperties": false,

  "properties": {
    "pactoVersion": {
      "type": "string",
      "enum": ["1.0"]
    },

    "service": {
      "type": "object",
      "required": ["name", "version"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([a-z0-9-]*[a-z0-9])?$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "owner": { "type": "string" },
        "image": {
          "type": "object",
          "required": ["ref"],
          "additionalProperties": false,
          "properties": {
            "ref": { "type": "string", "minLength": 1 },
            "private": { "type": "boolean" }
          }
        }
      }
    },

    "interfaces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "type": "string",
            "enum": ["http", "grpc", "event"]
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "visibility": {
            "type": "string",
            "enum": ["public", "internal"],
            "default": "internal"
          },
          "contract": { "type": "string", "minLength": 1 }
        },

        "allOf": [
          {
            "if": { "properties": { "type": { "const": "http" } } },
            "then": { "required": ["port"] }
          },
          {
            "if": { "properties": { "type": { "const": "grpc" } } },
            "then": { "required": ["port", "contract"] }
          },
          {
            "if": { "properties": { "type": { "const": "event" } } },
            "then": { "required": ["contract"] }
          }
        ]
      }
    },

    "configuration": {
      "type": "object",
      "required": ["schema"],
      "additionalProperties": false,
      "properties": {
        "schema": { "type": "string", "minLength": 1 }
      }
    },

    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["ref", "compatibility"],
        "additionalProperties": false,
        "properties": {
          "ref": { "type": "string", "minLength": 1 },
          "required": { "type": "boolean" },
          "compatibility": { "type": "string", "minLength": 1 }
        }
      }
    },

    "runtime": {
      "type": "object",
      "required": ["workload", "state", "health"],
      "additionalProperties": false,

      "properties": {

        "workload": {
          "type": "string",
          "enum": ["service", "job", "scheduled"]
        },

        "state": {
          "type": "object",
          "required": ["type", "persistence", "dataCriticality"],
          "additionalProperties": false,

          "properties": {
            "type": {
              "type": "string",
              "enum": ["stateless", "stateful", "hybrid"]
            },

            "persistence": {
              "type": "object",
              "required": ["scope", "durability"],
              "additionalProperties": false,
              "properties": {
                "scope": {
                  "type": "string",
                  "enum": ["local", "shared"]
                },
                "durability": {
                  "type": "string",
                  "enum": ["ephemeral", "persistent"]
                }
              }
            },

            "dataCriticality": {
              "type": "string",
              "enum": ["low", "medium", "high"]
            }
          },

          "allOf": [
            {
              "if": {
                "properties": {
                  "type": { "const": "stateless" }
                }
              },
              "then": {
                "properties": {
                  "persistence": {
                    "properties": {
                      "durability": { "const": "ephemeral" }
                    }
                  }
                }
              }
            }
          ]
        },

        "lifecycle": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "upgradeStrategy": {
              "type": "string",
              "enum": ["rolling", "recreate", "ordered"]
            },
            "gracefulShutdownSeconds": {
              "type": "integer",
              "minimum": 0
            }
          }
        },

        "health": {
          "type": "object",
          "required": ["interface"],
          "additionalProperties": false,
          "properties": {
            "interface": { "type": "string" },
            "path": { "type": "string" },
            "initialDelaySeconds": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },

    "scaling": {
      "type": "object",
      "required": ["min", "max"],
      "additionalProperties": false,
      "properties": {
        "min": { "type": "integer", "minimum": 0 },
        "max": { "type": "integer", "minimum": 0 }
      }
    },

    "metadata": {
      "type": "object"
    }
  }
}
